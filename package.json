{
  "name": "clearvault",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "obfuscate": "javascript-obfuscator .output/public/_nuxt --output .output/public/_nuxt --compact true --self-defending true",
    "build:full": "nuxt build && npm run obfuscate",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "nuxt": "^3.16.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "javascript-obfuscator": "^4.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
